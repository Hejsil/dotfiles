#!/usr/bin/env python3
"""
System update script - tries as many package managers as possible
Replacement for topgrade
"""

import sys
import subprocess
from pathlib import Path
from typing import List, Tuple

# ANSI color codes
RED = "\033[0;31m"
GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
BLUE = "\033[0;34m"
NC = "\033[0m"  # No Color


def command_exists(cmd: str) -> bool:
    """Check if a command exists in PATH"""
    result = subprocess.run(
        ["which", cmd], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
    )
    return result.returncode == 0


def path_exists(path: str) -> bool:
    """Check if a path exists"""
    return Path(path).exists()


def run_cmd(cmd: List[str]) -> bool:
    """Run a command and return success status"""
    try:
        result = subprocess.run(cmd)
        return result.returncode == 0
    except Exception as e:
        print(f"  Error: {e}", file=sys.stderr)
        return False


def get_docker_images() -> List[str]:
    """Return the list of locally available image references (repo:tag).

    Skips dangling images whose repository or tag is '<none>'.
    Returns an empty list if docker is missing or the query fails.
    """
    if not command_exists("docker"):
        return []
    try:
        result = subprocess.run(
            ["docker", "images", "--format", "{{.Repository}}:{{.Tag}}"],
            capture_output=True,
            text=True,
        )
    except Exception:
        return []
    if result.returncode != 0:
        return []
    images = []
    for line in result.stdout.splitlines():
        line = line.strip()
        if not line or "<none>" in line:
            continue
        images.append(line)
    return images


def main():
    # Track results
    results = {"succeeded": [], "failed": [], "skipped": []}

    # Format: (name, [command])
    commands: List[Tuple[str, List[str]]] = [
        # System package managers
        ("APT Update", ["sudo", "apt", "update"]),
        ("APT Upgrade", ["sudo", "apt", "upgrade", "-y"]),
        ("APT Autoremove", ["sudo", "apt", "autoremove", "-y"]),
        ("Snap", ["sudo", "snap", "refresh"]),
        ("Pacman", ["sudo", "pacman", "-Syu", "--noconfirm"]),
        ("Yay", ["aur-scan-wrap", "yay", "-Syu", "--noconfirm"]),
        ("Paru", ["aur-scan-wrap", "paru", "-Syu", "--noconfirm"]),
        ("Firmware (fwupd)", ["sudo", "fwupdmgr", "update"]),
        ("Dipm", ["dipm", "update"]),

        # Language/tool managers
        ("Pipx", ["pipx", "upgrade-all"]),

        # Export package lists back to dotfiles
        ("Export Packages", ["export-packages"]),
    ]

    # Add a `docker pull` for each locally available image so existing/skipped
    # package-manager handling applies uniformly (missing docker skips them).
    for img in get_docker_images():
        commands.append((f"Docker Image {img}", ["docker", "pull", img]))

    # Run all commands
    for name, cmd in commands:
        # A command is either:
        # * <cmd> <args...>
        # * sudo <cmd> <args...>
        # * aur-scan-wrap <cmd> <args...>
        # * docker pull <image>        (one per locally available image)
        #
        # We need to check both the wrapper and the actual command for
        # existence
        if not command_exists(cmd[0]):
            results["skipped"].append(name)
            continue

        wrappers = ["sudo", "aur-scan-wrap"]
        check_second_cmd = len(cmd) > 1 and cmd[0] in wrappers
        if check_second_cmd and not command_exists(cmd[1]):
            results["skipped"].append(name)
            continue

        # Print header
        print(f"\n{'─' * 60}", file=sys.stderr)
        print(f"▶ {name}", file=sys.stderr)
        print(f"{'─' * 60}", file=sys.stderr)

        if run_cmd(cmd):
            print(f"{GREEN}[✓]{NC} {name} updated", file=sys.stderr)
            results["succeeded"].append(name)
        else:
            print(f"{RED}[✗]{NC} {name} update failed", file=sys.stderr)
            results["failed"].append(name)

    # Print summary
    print(file=sys.stderr)
    print(f"{'─' * 60}", file=sys.stderr)
    print("▶ Summary", file=sys.stderr)
    print(f"{'─' * 60}", file=sys.stderr)

    if results["succeeded"]:
        print(f"\n{GREEN}✓ Succeeded ({len(results['succeeded'])}){NC}:", file=sys.stderr)
        for cmd in results["succeeded"]:
            print(f"  • {cmd}", file=sys.stderr)

    if results["failed"]:
        print(f"\n{RED}✗ Failed ({len(results['failed'])}){NC}:", file=sys.stderr)
        for cmd in results["failed"]:
            print(f"  • {cmd}", file=sys.stderr)

    if results["skipped"]:
        print(f"\n{YELLOW}⊘ Skipped ({len(results['skipped'])}){NC}:", file=sys.stderr)
        for cmd in results["skipped"]:
            print(f"  • {cmd}", file=sys.stderr)

    print(file=sys.stderr)
    return 1 if results["failed"] else 0


if __name__ == "__main__":
    sys.exit(main())
