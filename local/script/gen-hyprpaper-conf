#!/bin/sh -e
CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/hypr"
CONF="$CONF_DIR/hyprpaper.conf"
WALLPAPERS_DIR="$HOME/Pictures/wallpapers"


tmp=$(mktemp "$CONF_DIR/.hyprpaper.conf.XXXXXX")
wallpaper_format_string="
wallpaper {
    monitor = %
    path = $WALLPAPERS_DIR
    recursive = true
    order = random
    timeout = 0
    fit_mode = cover
}"

{
  echo '# Generated by gen-hyprpaper-conf — do not edit wallpaper blocks by hand.
# Re-run on display changes / before hyprpaper starts.
splash = false'
  monitors |
    jq '.name' -r |
    nargs -I% echo "$wallpaper_format_string"
} > "$tmp"

mv -f "$tmp" "$CONF"
echo "gen-hyprpaper-conf: wrote monitor block(s) to $CONF"
